---
import { getCollection } from 'astro:content';
import { href } from '../../config';
import { parseNoteId } from '../../i18n';
import { filterNotesByLocale } from '../../utils/notes';
import { getBrowsableMonths } from '../../utils/studyGrass';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  const enNotes = filterNotesByLocale(allNotes, 'en');
  const translationIds = new Set(enNotes.map((n) => parseNoteId(n.id).translationId));
  const months = getBrowsableMonths(enNotes);

  const slugs = [...translationIds, ...months];

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const slug = Astro.params.slug ?? '';
return Astro.redirect(href(`/notes/${slug}/`));
---
