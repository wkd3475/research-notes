---
import { getCollection } from 'astro:content';
import NoteLayout from '../../../../../layouts/NoteLayout.astro';
import { href } from '../../../../../config';
import { locales, isLocale, parseNoteId } from '../../../../../i18n';
import { filterNotesByLocale } from '../../../../../utils/notes';
import {
  getFileAtRevision,
  getNoteRevisions,
  noteContentPath,
  noteMetaPath,
  parseNoteFile,
  parseNoteMeta,
  resolveRevisionSha,
} from '../../../../../utils/noteHistory';
import { renderMarkdown } from '../../../../../utils/renderMarkdown';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');

  return locales.flatMap((locale) =>
    filterNotesByLocale(allNotes, locale).flatMap((note) => {
      const { translationId } = parseNoteId(note.id);
      const contentPath = noteContentPath(locale, translationId);
      const revisions = getNoteRevisions(contentPath);

      return revisions.slice(1).map((revision) => ({
        params: { locale, slug: translationId, sha: revision.shortSha },
        props: {
          locale,
          translationId,
          sha: revision.sha,
          revisionDate: revision.date,
        },
      }));
    }),
  );
}

const { locale, translationId, sha, revisionDate } = Astro.props;

if (!isLocale(locale)) {
  return Astro.redirect(href('/notes/'));
}

const contentPath = noteContentPath(locale, translationId);
const metaPath = noteMetaPath(locale, translationId);
const fullSha = resolveRevisionSha(contentPath, sha);

if (!fullSha) {
  return Astro.redirect(href(`/notes/${translationId}/`, locale));
}

const rawContent = getFileAtRevision(contentPath, fullSha);
if (!rawContent) {
  return Astro.redirect(href(`/notes/${translationId}/`, locale));
}

const parsed = parseNoteFile(rawContent);
const rawMeta = getFileAtRevision(metaPath, fullSha);
const meta = rawMeta ? parseNoteMeta(rawMeta) : { tags: [], exploreNext: [] };
const revisions = getNoteRevisions(contentPath);
const html = renderMarkdown(parsed.body);
---

<NoteLayout
  title={parsed.title}
  description={meta.description}
  pubDate={meta.pubDate ?? revisionDate}
  tags={meta.tags}
  exploredFrom={meta.exploredFrom}
  locale={locale}
  translationId={translationId}
  revisions={revisions}
  revisionBanner={{ date: revisionDate, sha: fullSha }}
>
  <div set:html={html} />
</NoteLayout>
