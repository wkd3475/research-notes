---
import { themes, DEFAULT_THEME } from '../themes';
import { colorModes } from '../colorMode';
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);

const colorModeLabels: Record<(typeof colorModes)[number], string> = {
  light: strings.colorModeLight,
  dark: strings.colorModeDark,
  system: strings.colorModeSystem,
};
---

<div class="theme-picker">
  <button
    type="button"
    class="theme-picker-toggle"
    aria-label={strings.themePicker}
    aria-expanded="false"
    aria-haspopup="dialog"
    id="theme-picker-toggle"
  >
    <span class="theme-picker-current" id="theme-picker-current" data-theme={DEFAULT_THEME}></span>
  </button>
  <div class="theme-picker-menu" id="theme-picker-menu" role="dialog" aria-label={strings.themePicker} hidden>
    <p class="theme-picker-section-label">{strings.colorMode}</p>
    <div class="color-mode-toggle" role="group" aria-label={strings.colorMode}>
      {
        colorModes.map((mode) => (
          <button
            type="button"
            class="color-mode-option"
            data-color-mode={mode}
            aria-pressed="false"
          >
            {colorModeLabels[mode]}
          </button>
        ))
      }
    </div>
    <p class="theme-picker-section-label">{strings.accentTheme}</p>
    <ul class="theme-picker-swatches" role="listbox" aria-label={strings.accentTheme}>
      {
        themes.map((theme) => (
          <li role="option">
            <button
              type="button"
              class="theme-picker-option"
              data-theme={theme.id}
              aria-label={theme.label}
              title={theme.label}
            >
              <span class="theme-swatch" style={`background: ${theme.swatch}`}></span>
            </button>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<script>
  import {
    applyColorMode,
    isColorMode,
    readStoredColorMode,
    type ColorMode,
  } from '../colorMode';
  import { DEFAULT_THEME, THEME_STORAGE_KEY, isThemeId } from '../themes';

  const toggle = document.getElementById('theme-picker-toggle');
  const menu = document.getElementById('theme-picker-menu');
  const current = document.getElementById('theme-picker-current');

  const applyTheme = (themeId: string) => {
    if (!isThemeId(themeId)) return;
    document.documentElement.setAttribute('data-theme', themeId);
    localStorage.setItem(THEME_STORAGE_KEY, themeId);
    if (current) current.setAttribute('data-theme', themeId);
    menu?.querySelectorAll('.theme-picker-option').forEach((btn) => {
      btn.setAttribute('aria-selected', btn.getAttribute('data-theme') === themeId ? 'true' : 'false');
    });
  };

  const syncColorModeUi = (mode: ColorMode) => {
    menu?.querySelectorAll('.color-mode-option').forEach((btn) => {
      const value = btn.getAttribute('data-color-mode');
      const isActive = value === mode;
      btn.classList.toggle('is-active', isActive);
      btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });
  };

  const setColorMode = (mode: ColorMode) => {
    applyColorMode(mode);
    syncColorModeUi(mode);
  };

  const savedTheme = localStorage.getItem(THEME_STORAGE_KEY);
  if (savedTheme && isThemeId(savedTheme)) {
    applyTheme(savedTheme);
  } else {
    applyTheme(DEFAULT_THEME);
  }

  setColorMode(readStoredColorMode());

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (readStoredColorMode() === 'system') {
      applyColorMode('system');
    }
  });

  const closeMenu = () => {
    menu?.setAttribute('hidden', '');
    toggle?.setAttribute('aria-expanded', 'false');
  };

  const openMenu = () => {
    menu?.removeAttribute('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
  };

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (menu?.hasAttribute('hidden')) openMenu();
    else closeMenu();
  });

  menu?.querySelectorAll('.color-mode-option').forEach((btn) => {
    btn.addEventListener('click', () => {
      const mode = btn.getAttribute('data-color-mode');
      if (mode && isColorMode(mode)) setColorMode(mode);
    });
  });

  menu?.querySelectorAll('.theme-picker-option').forEach((btn) => {
    btn.addEventListener('click', () => {
      const themeId = btn.getAttribute('data-theme');
      if (themeId) applyTheme(themeId);
    });
  });

  document.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
