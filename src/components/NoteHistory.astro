---
import { href } from '../config';
import { type Locale, t } from '../i18n';
import {
  type NoteRevision,
  formatNoteDate,
  formatRevisionDate,
  getFirstWrittenDate,
  getLastUpdatedDate,
  githubCommitUrl,
  shouldShowLastUpdated,
} from '../utils/noteHistory';

interface Props {
  locale: Locale;
  translationId: string;
  pubDate: Date;
  revisions: NoteRevision[];
}

const { locale, translationId, pubDate, revisions } = Astro.props;
const strings = t(locale);

const formattedPubDate = formatNoteDate(pubDate, locale);
const firstWritten = getFirstWrittenDate(pubDate, revisions);
const lastUpdated = getLastUpdatedDate(revisions);
const showLastUpdated = shouldShowLastUpdated(firstWritten, revisions);
const hasHistory = revisions.length > 0;
const formattedFirstWritten = hasHistory
  ? formatRevisionDate(firstWritten, locale)
  : formattedPubDate;
---

<dl class="note-meta-panel">
  <div class="note-meta-row">
    <dt class="note-meta-label">{strings.firstWritten}</dt>
    <dd class="note-meta-value">
      {
        hasHistory ? (
          <details class="note-history-details">
            <summary class="note-meta-date note-meta-date--interactive">
              <time datetime={firstWritten.toISOString()}>{formattedFirstWritten}</time>
              <span class="note-meta-hint">{strings.viewEditHistory}</span>
            </summary>
            <ul class="note-history-list">
              {revisions.map((revision, index) => {
                const isCurrent = index === 0;
                const revisionHref = isCurrent
                  ? href(`/notes/${translationId}/`, locale)
                  : href(`/notes/${translationId}/revision/${revision.shortSha}/`, locale);

                return (
                  <li class="note-history-item">
                    <a class="note-history-link" href={revisionHref}>
                      <time datetime={revision.date.toISOString()}>{formatRevisionDate(revision.date, locale)}</time>
                      {isCurrent && <span class="note-history-badge">{strings.currentVersion}</span>}
                      <span class="note-history-message">{revision.message}</span>
                    </a>
                    <a
                      class="note-history-diff"
                      href={githubCommitUrl(revision.sha)}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {strings.viewDiff}
                    </a>
                  </li>
                );
              })}
            </ul>
          </details>
        ) : (
          <time class="note-meta-date" datetime={pubDate.toISOString()}>{formattedPubDate}</time>
        )
      }
    </dd>
  </div>

  {
    showLastUpdated && lastUpdated && (
      <div class="note-meta-row">
        <dt class="note-meta-label">{strings.lastUpdated}</dt>
        <dd class="note-meta-value">
          <time class="note-meta-date" datetime={lastUpdated.toISOString()}>
            {formatRevisionDate(lastUpdated, locale)}
          </time>
        </dd>
      </div>
    )
  }
</dl>
