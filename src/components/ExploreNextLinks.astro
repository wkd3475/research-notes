---
import { href } from '../config';
import type { ExploreNextItem } from '../content.config';
import { type Locale, t, parseNoteId } from '../i18n';
import { buildNextResearchPrompt, encodeCopyText } from '../utils/nextResearchPrompt';
import { filterNotesByLocale } from '../utils/notes';
import { getCollection } from 'astro:content';

type ExploreNextDisplayItem = ExploreNextItem & { fromTitle?: string };

interface Props {
  items: ExploreNextDisplayItem[];
  locale: Locale;
  compact?: boolean;
  fromTitle?: string;
}

const { items, locale, compact = false, fromTitle } = Astro.props;
const strings = t(locale);

if (items.length === 0) return;

const allNotes = await getCollection('notes');
const localeNotes = filterNotesByLocale(allNotes, locale);
const noteTitles = new Map(
  localeNotes.map((n) => [parseNoteId(n.id).translationId, n.data.title]),
);
---

<section class:list={['explore-next', compact && 'explore-next--compact']}>
  <h3 class="explore-next-heading">{strings.nextResearch}</h3>
  <ul class="explore-next-list">
    {
      items.map((item) => {
        const linkedTitle = item.note ? noteTitles.get(item.note) : undefined;
        const isLinked = item.note && linkedTitle;
        const itemFromTitle = item.fromTitle ?? fromTitle;
        const copyText = !isLinked
          ? buildNextResearchPrompt(locale, item, itemFromTitle)
          : undefined;
        const copyTextB64 = copyText ? encodeCopyText(copyText) : undefined;

        return (
          <li class:list={['explore-next-item', !isLinked && 'explore-next-item--pending']}>
            {
              isLinked ? (
                <a class="explore-next-link" href={href(`/notes/${item.note}/`, locale)}>
                  <svg
                    class="explore-next-icon explore-next-icon--link"
                    viewBox="0 0 20 20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    aria-hidden="true"
                  >
                    <path d="M7 4h9v9" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M16 4 4 16" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  <span class="explore-next-content">
                    <span class="explore-next-label">{item.label}</span>
                    {item.reason && <span class="explore-next-reason">{item.reason}</span>}
                    {item.fromTitle && <span class="explore-next-source">{item.fromTitle}</span>}
                    {
                      linkedTitle !== item.label && (
                        <span class="explore-next-target">{linkedTitle}</span>
                      )
                    }
                  </span>
                </a>
              ) : (
                <button
                  type="button"
                  class="explore-next-link explore-next-link--pending explore-next-copy-btn"
                  title={strings.pendingCopyHint}
                  data-copy-text-b64={copyTextB64}
                  data-copy-toast={strings.copyGuideToast}
                >
                  <svg
                    class="explore-next-icon explore-next-icon--pending"
                    viewBox="0 0 20 20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    aria-hidden="true"
                  >
                    <rect x="6" y="6" width="11" height="11" rx="1.5" stroke-linecap="round" />
                    <path
                      d="M4 14V4.5A1.5 1.5 0 0 1 5.5 3H13"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  <span class="explore-next-content">
                    <span class="explore-next-label">{item.label}</span>
                    {item.reason && <span class="explore-next-reason">{item.reason}</span>}
                    {item.fromTitle && <span class="explore-next-source">{item.fromTitle}</span>}
                    <span class="explore-next-badge">{strings.pendingNote}</span>
                  </span>
                </button>
              )
            }
          </li>
        );
      })
    }
  </ul>
</section>

<script>
  import '../scripts/explore-next-copy.ts';
</script>
