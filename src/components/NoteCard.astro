---
import ExploreNextLinks from './ExploreNextLinks.astro';
import TagList from './TagList.astro';
import type { ExploreNextItem } from '../content.config';
import type { Locale } from '../i18n';
import { formatNoteDate } from '../utils/noteHistory';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags: string[];
  href: string;
  exploreNext?: ExploreNextItem[];
  locale: Locale;
}

const { title, description, pubDate, tags, href, exploreNext = [], locale } = Astro.props;

const formattedDate = formatNoteDate(pubDate, locale, 'short');
---

<article class="card note-card">
  <p class="note-meta">{formattedDate}</p>
  <h2><a href={href}>{title}</a></h2>
  {description && <p class="note-desc">{description}</p>}
  <TagList tags={tags} locale={locale} />
  {exploreNext.length > 0 && (
    <ExploreNextLinks items={exploreNext} locale={locale} compact fromTitle={title} />
  )}
</article>
