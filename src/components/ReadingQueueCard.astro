---
import type { Locale } from '../i18n';
import { t } from '../i18n';
import TagList from './TagList.astro';
import { formatNoteDate } from '../utils/noteHistory';

interface Props {
  title: string;
  url: string;
  reason: string;
  savedAt: Date;
  tags: string[];
  source?: string;
  locale: Locale;
}

const { title, url, reason, savedAt, tags, source, locale } = Astro.props;
const strings = t(locale);
const formattedDate = formatNoteDate(savedAt, locale, 'short');
---

<article class="card reading-queue-card">
  <p class="note-meta">
    {strings.savedOn} {formattedDate}
    {source && <span class="reading-queue-source"> · {source}</span>}
  </p>
  <h2>
    <a href={url} target="_blank" rel="noopener noreferrer">{title}</a>
  </h2>
  <p class="reading-queue-reason">{reason}</p>
  <TagList tags={tags} locale={locale} />
</article>
