---
import BaseLayout from './BaseLayout.astro';
import ExploreNextLinks from '../components/ExploreNextLinks.astro';
import NoteAdjacentNav from '../components/NoteAdjacentNav.astro';
import NoteHistory from '../components/NoteHistory.astro';
import PreviousResearchLinks from '../components/PreviousResearchLinks.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import TagList from '../components/TagList.astro';
import { href } from '../config';
import type { ExploreNextItem } from '../content.config';
import { type Locale, t } from '../i18n';
import { findReferrerNotes, getAdjacentNotes } from '../utils/notes';
import { formatRevisionDate, type NoteRevision } from '../utils/noteHistory';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags: string[];
  exploreNext?: ExploreNextItem[];
  exploredFrom?: string;
  locale: Locale;
  translationId: string;
  revisions?: NoteRevision[];
  revisionBanner?: {
    date: Date;
    sha: string;
  };
}

const {
  title,
  description,
  pubDate,
  tags,
  exploreNext = [],
  exploredFrom,
  locale,
  translationId,
  revisions = [],
  revisionBanner,
} = Astro.props;

const strings = t(locale);

const allNotes = await getCollection('notes');
const referrerNotes = findReferrerNotes(allNotes, translationId, locale, exploredFrom);
const adjacentNotes = getAdjacentNotes(allNotes, translationId, locale);
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  translationId={translationId}
>
  <article class="note-content" id="note-top">
    <a class="back-link" href={href('/notes/', locale)}>{strings.backToNotes}</a>

    {referrerNotes.length > 0 && (
      <PreviousResearchLinks items={referrerNotes} locale={locale} />
    )}

    {
      revisionBanner && (
        <div class="revision-banner" role="status">
          <p>
            {strings.viewingRevision}{' '}
            <time datetime={revisionBanner.date.toISOString()}>
              {formatRevisionDate(revisionBanner.date, locale)}
            </time>
          </p>
          <a class="revision-banner-link" href={href(`/notes/${translationId}/`, locale)}>
            {strings.backToCurrent}
          </a>
        </div>
      )
    }

    <h1>{title}</h1>
    <div class="note-meta">
      <NoteHistory
        locale={locale}
        translationId={translationId}
        pubDate={pubDate}
        revisions={revisions}
      />
    </div>
    <TagList tags={tags} locale={locale} />
    <slot />
    {exploreNext.length > 0 && (
      <ExploreNextLinks items={exploreNext} locale={locale} fromTitle={title} />
    )}
    <NoteAdjacentNav adjacent={adjacentNotes} locale={locale} />
    <ScrollToTop locale={locale} />
  </article>
</BaseLayout>
